# ──────────────────────────────────────────────
# Smart Fuel - Variables de Entorno
# Copia este archivo a .env y completa los valores
# ──────────────────────────────────────────────

# App
NODE_ENV=production
PORT=3000
# En producción, usa la URL de tu dominio o IP del servidor
CORS_ORIGINS=http://localhost

# Database
# Opción A: String de conexión (Supabase/Render/Railway)
DATABASE_URL=postgres://user:password@host:port/dbname

# Opción B: Variables separadas (Local Docker)
DB_HOST=localhost
DB_PORT=5432
DB_USER=smart_user
DB_PASSWORD=your_password_here
DB_NAME=smart_fuel_db
DB_SSL=false

# JWT
JWT_SECRET=change_this_super_secret_key_in_production
JWT_EXPIRES_IN=7d

# Mapbox (requiere cuenta en mapbox.com)
MAPBOX_API_KEY=pk.eyJ1IjoiTUlfVVNVQVJJTyIsImEiOiJNSV9UT0tFTiJ9.REEMPLAZAR

# Anomaly detection threshold (porcentaje, ej: 0.15 = 15%)
ANOMALY_THRESHOLD=0.15

# Safety buffer por defecto (porcentaje)
DEFAULT_SAFETY_BUFFER=0.15
